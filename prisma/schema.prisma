generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  dni      String   @id
  email    String   @unique
  password String
  fullName String
  telefono String
  isActive Boolean  @default(true)
  roles    String[] @default(["user"])

  conductor Conductor?
  averias   Averia[]
}

model Conductor {
  dni             String   @id
  nombre          String
  apellidos       String
  telefono        String
  direccion       String
  fechaNacimiento DateTime

  image Image?

  vehiculo Vehiculo[]

  userDni String? @unique
  user    User?   @relation(fields: [userDni], references: [dni])
  viajes  Viaje[]
}

model Trayecto {
  id            String   @id @default(uuid())
  horaSalida    DateTime
  horaLlegada   DateTime
  origen        String
  destino       String
  distanciaEnKm Float

  viajeId String?
  viaje   Viaje?  @relation(fields: [viajeId], references: [id], onDelete: Cascade)
}

//Aunque no salga en la base de datos. Al devolver el json de un Viaje puedo añadir el campo gasto sumando el gasto de todos sus trayectos
model Viaje {
  id                String  @id @default(uuid())
  descripcion       String
  kmSalida          Float?
  kmLlegada         Float?
  origen            String
  destino           String
  combustibleInicio Float?
  combustibleFinal  Float?
  visible           Boolean

  vehiculoMatricula String?
  vehiculo          Vehiculo? @relation(fields: [vehiculoMatricula], references: [matricula], onDelete: SetNull)

  conductorDni String?
  conductor    Conductor? @relation(fields: [conductorDni], references: [dni], onDelete: SetNull)

  revision  Revision?
  trayectos Trayecto[]
}

model Vehiculo {
  id                 String   @id @default(uuid())
  matricula          String   @unique
  marca              String
  modelo             String
  fechaCompra        DateTime
  fechaMatriculacion DateTime
  tipo               String
  kilometrosTotales  Float
  alimentacion       String
  precio             Float    @default(0)

  conductorDni String?
  conductor    Conductor? @relation(fields: [conductorDni], references: [dni], onDelete: SetNull)

  plantillaId String?
  plantilla   Plantilla? @relation(fields: [plantillaId], references: [id], onDelete: SetNull)

  imagenes   Image[]
  revisiones Revision[]
  averias    Averia[]
  viajes     Viaje[]
}

model Revision {
  id             String   @id @default(uuid())
  fecha          DateTime
  lugar          String?
  aprobada       Boolean?
  costo          Float?
  visible        Boolean
  esItv          Boolean  @default(false)
  matriculaTexto String

  vehiculoMatricula String?
  vehiculo          Vehiculo? @relation(fields: [vehiculoMatricula], references: [matricula], onDelete: SetNull)

  viajeId String? @unique
  viaje   Viaje?  @relation(fields: [viajeId], references: [id], onDelete: SetNull)
}

model Plantilla {
  id     String @id @default(uuid())
  nombre String

  rangos    Rango[]
  vehiculos Vehiculo[]
}

model Rango {
  id                   String @id @default(uuid())
  desdeAnyo            Int?
  desdeKilometro       Int?
  frecuenciaMeses      Int?
  frecuenciaKilometros Int?

  plantillaId  String?
  plantillaITV Plantilla? @relation(fields: [plantillaId], references: [id], onDelete: Cascade)
}

model Averia {
  id                      String    @id @default(uuid())
  descripcion             String
  fechaAveria             DateTime
  fechaComienzoReparacion DateTime?
  fechaFinReparacion      DateTime?
  lugarReparacion         String?
  costeReparacion         Float?
  resuelta                Boolean   @default(false)

  vehiculoMatricula String
  vehiculo          Vehiculo @relation(fields: [vehiculoMatricula], references: [matricula], onDelete: SetNull)

  userDni String
  user    User   @relation(fields: [userDni], references: [dni], onDelete: SetNull)
}

model Image {
  id             String  @id @default(uuid())
  url            String  @unique
  nombre         String  @unique
  fromCloudinary Boolean

  vehiculoMatricula String?
  vehiculo          Vehiculo? @relation(fields: [vehiculoMatricula], references: [matricula], onDelete: Cascade)

  conductorDni String?    @unique
  conductor    Conductor? @relation(fields: [conductorDni], references: [dni], onDelete: Cascade)
}
