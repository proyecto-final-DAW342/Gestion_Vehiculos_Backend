generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  dni      String   @id
  email    String   @unique
  password String
  fullName String
  telefono String
  isActive Boolean  @default(true)
  roles    String[] @default(["user"])

  @@map("users")
}

model Conductor {
  dni             String   @id
  nombre          String
  apellidos       String
  telefono        String
  direccion       String
  fechaNacimiento DateTime

  image Images?

  vehiculo Vehiculo[]
}

model Trayecto {
  id            Int      @id
  horaSalida    DateTime
  horaLlegada   DateTime
  origen        String
  destino       String
  distanciaEnKm Float
  completado    Boolean //Esto tal vez no sea necesario
  gasto         Float

  viajeId Int
  viaje   Viaje @relation(fields: [viajeId], references: [id], onDelete: Cascade)
}

//Aunque no salga en la base de datos. Al devolver el json de un Viaje puedo añadir el campo gasto sumando el gasto de todos sus trayectos
model Viaje {
  id        Int     @id @default(autoincrement())
  kmSalida  Float
  kmLlegada Float
  visible   Boolean

  vehiculoMatricula String?
  vehiculo          Vehiculo? @relation(fields: [vehiculoMatricula], references: [matricula], onDelete: SetNull)

  revision  Revision?
  trayectos Trayecto[]
}

//Se podría poner un uid para permitir modificar la matrícula fácilmente. Esto se hará cuando la base de datos no tengo datos
model Vehiculo {
  matricula         String   @id @default(uuid())
  marca             String
  modelo            String
  fechaCompra       DateTime
  anyosAntiguedad   Int
  tipo              String
  kilometrosTotales Float
  alimentacion      String
  precio            Float    @default(0)
  gastoPorKm        Float

  conductorDni String?
  conductor    Conductor? @relation(fields: [conductorDni], references: [dni], onDelete: SetNull)

  //Cuando una revisión de complete, una avería se resuelva o un viaje termine, se puede preguntar al usuario si desea ocultarla 
  //Cuando un vehículo se borre, sus revisiones, averias y viajes se ocutarán (tal vez preguntándole al usuario) para que sigan siendo accesibles
  imagenes   Images[]
  revisiones Revision[]
  averias    Averia[]
  viajes     Viaje[]

  @@map("vehiculos")
}

model Revision {
  id       String   @id @default(uuid())
  fecha    DateTime
  lugar    String
  aprobada Boolean
  costo    Float
  visible  Boolean

  vehiculoMatricula String?
  vehiculo          Vehiculo? @relation(fields: [vehiculoMatricula], references: [matricula], onDelete: SetNull)

  viajeId Int?   @unique
  viaje   Viaje? @relation(fields: [viajeId], references: [id], onDelete: SetNull)
}

//Para ir a la reparación de la avería hace falta un trayecto
model Averia {
  id                      Int      @id
  descripcion             String
  fechaAveria             DateTime
  fechaComienzoReparacion DateTime
  fechaFinReparacion      DateTime
  lugarReparacion         String
  costeReparacion         Float

  vehiculoMatricula String?
  vehiculo          Vehiculo? @relation(fields: [vehiculoMatricula], references: [matricula], onDelete: SetNull)
}

//Cambiar Images a Image cuando no haya datos
model Images {
  id             Int     @id @default(autoincrement())
  url            String  @unique
  nombre         String  @unique
  fromCloudinary Boolean

  vehiculoMatricula String?
  vehiculo          Vehiculo? @relation(fields: [vehiculoMatricula], references: [matricula], onDelete: Cascade)

  conductorDni String?    @unique
  conductor    Conductor? @relation(fields: [conductorDni], references: [dni], onDelete: Cascade)
}
