generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  dni      String   @id
  email    String   @unique
  password String
  fullName String
  telefono String
  isActive Boolean  @default(true)
  roles    String[] @default(["user"])

  @@map("users")
}

model Conductor {
  dni             String   @id
  nombre          String
  apellidos       String
  telefono        String
  direccion       String
  fechaNacimiento DateTime

  images Images?

  vehiculo                Vehiculo[]
  infoEspecificaTrayectos InfoEspecificaTrayecto[]
}

model InfoEspecificaTrayecto {
  id           Int        @id
  activo       Boolean
  completado   Boolean //Esto tal vez no sea necesario
  gasto        Float //Esto se peuede calcular en el backend según el vehículo y así no tengo que duplicar trayectos
  conductor    Conductor? @relation(fields: [conductorDni], references: [dni]) // Tal vez se pueda hacer un array por si varios conductores hacen el mismo trayecto no duplicarlos
  conductorDni String?
  trayecto     Trayecto?  @relation(fields: [trayectoId], references: [id])
  trayectoId   Int?
}

model Trayecto {
  id            Int      @id
  horaSalida    DateTime
  horaLlegada   DateTime
  origen        String
  destino       String
  distanciaEnKm Float

  viajeId Int?
  viaje   Viaje? @relation(fields: [viajeId], references: [id])

  infoEspecifica InfoEspecificaTrayecto[]
}

model Viaje {
  id        Int        @id
  trayectos Trayecto[]
}

model Vehiculo {
  matricula         String   @id @default(uuid())
  marca             String   @unique
  modelo            String
  fechaCompra       DateTime
  anyosAntiguedad   Int
  tipo              String
  kilometrosTotales Float
  alimentacion      String
  precio            Float    @default(0)
  gastoPorKm        Float

  conductorDni String?
  conductor    Conductor? @relation(fields: [conductorDni], references: [dni])

  imagenes   Images[]
  revisiones Revision[]
  averias    Averia[]

  @@map("vehiculos")
}

//Para ir a la revision hace falta un trayecto
model Revision {
  id       String   @id @default(uuid())
  fecha    DateTime
  lugar    String
  aprobada Boolean

  vehiculoMatricula String?
  vehiculo          Vehiculo? @relation(fields: [vehiculoMatricula], references: [matricula])
}

//Para ir a la reparación de la avería hace falta un trayecto
model Averia {
  id                      Int      @id
  descripcion             String
  fechaAveria             DateTime
  fechaComienzoReparacion DateTime
  fechaFinReparacion      DateTime
  lugarReparacion         String
  costeReparacion         Float

  vehiculoMatricula String?
  vehiculo          Vehiculo? @relation(fields: [vehiculoMatricula], references: [matricula])
}

//Cambiar Images a Image cuando no haya datos
model Images {
  id     Int    @id @default(autoincrement())
  url    String @unique
  nombre String @unique

  vehiculoMatricula String?
  vehiculo          Vehiculo? @relation(fields: [vehiculoMatricula], references: [matricula], onDelete: Cascade)

  conductorDni String?    @unique
  conductor    Conductor? @relation(fields: [conductorDni], references: [dni], onDelete: Cascade)
}
